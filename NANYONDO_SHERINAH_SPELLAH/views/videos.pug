doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Videx - Dashboard
    // Bootstrap
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
    // Bootstrap Icons
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css')
    style.
      body {
        background: #f3f3f3;
        font-family: Arial, Helvetica, sans-serif;
      }
      .navbar-brand {
        font-size: 2rem;
        font-weight: bold;
        color: red !important;
      }
      .logo-icon {
        color: red;
        margin-right: 8px;
      }
      .section-title {
        font-size: 1.7rem;
        font-weight: 600;
      }
      .video-card {
        border: none;
        background: transparent;
      }
      .video-player {
        width: 100%;
        height: 160px;
        border-radius: 6px;
        background-color: #000;
        object-fit: cover;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      }
      .video-title {
        font-weight: 600;
        font-size: 1rem;
        line-height: 1.3;
      }
      .video-meta {
        font-size: 0.85rem;
        color: #777;
      }
      .menu-btn {
        border: none;
        background: transparent;
        font-size: 1.2rem;
        color: #444;
      }
      .add-btn {
        border: 2px solid red;
        color: red;
        font-weight: 600;
        padding: 10px 40px;
        text-decoration: none;
        display: inline-block;
      }
      .add-btn:hover {
        background: red;
        color: white;
      }
  body
    .container-fluid.px-4.py-3
      .d-flex.justify-content-between.align-items-center.mb-3
        .navbar-brand.m-0
          i.bi.bi-play-circle-fill.logo-icon
          | Videx
        a.btn.add-btn(href='/add')
          | Add Video
      h3.section-title Videos
      hr
      
      .row.g-4
        if videos && videos.length > 0
          each video in videos
            .col-lg-3.col-md-4.col-sm-6
              .video-card
                //- Active Video element streaming the uploaded file paths
                video.video-player(src=video.videoUrl poster=video.thumbnailUrl controls)
                
                .d-flex.justify-content-between.mt-2
                  h6.video-title.mb-0
                    | #{video.title}
                  button.menu-btn
                    i.bi.bi-three-dots-vertical
                .video-meta
                  | #{video.views} views • #{video.timeAgo}
        else
          .col-12.text-center.py-5
            p.text-muted.fs-5 No videos uploaded yet. Click "Add Video" to populate your feed!